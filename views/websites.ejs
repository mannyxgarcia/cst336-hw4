<!doctype html>
<html lang="en">
  <%- include('partials/head.ejs') %>

  <body>
    <div id="main_div">
      <%- include('partials/header.ejs') %>
      <%- include('partials/nav.ejs') %>

      <main class="grid-layout">

        <%- include('partials/left-sidebar.ejs') %>

        <section class="page_content">

          <h2>Popular Websites</h2>

          <figure>
            <img
              src="/img/online_now.gif"
              class="computer-gif"
              alt="Early Internet websites"
            />

            <figcaption>
              Many classic websites helped shape online culture in the
              late 1990s and early 2000s.
            </figcaption>
          </figure>

          <p>
            Before social media became popular, people explored the
            Internet through search engines, personal websites,
            chat rooms, and online communities. Many of these websites
            introduced new ways to communicate and share information.
          </p>

          <% websites.forEach((website) => { %>

            <div class="website-card">

              <h3><%= website.name %></h3>

              <p>
                <%= website.description %>
              </p>

              <% if (website.available) { %>

                <p>
                  <strong>Archived Snapshot:</strong>
                  <%= website.formattedDate %>
                </p>

                <a
                  class="archive-button"
                  href="<%= website.snapshotUrl %>"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Visit Archived Website
                </a>

              <% } else { %>

                <p>
                  No archived snapshot was found.
                </p>

              <% } %>

            </div>

          <% }) %>

        </section>

        <%- include('partials/right-sidebar.ejs') %>

      </main>

      <%- include('partials/footer.ejs') %>

    </div>
  </body>
</html>
